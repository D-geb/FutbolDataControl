// C:\DataFlex Projects\FutbolDataControl\AppSrc\SelectJugador.wo
// SelectJugador
//


Use cWebView.pkg
Use cWebList.pkg
Use cWebMenuGroup.pkg
Use cWebMenuItem.pkg
Use cWebColumnButton.pkg
Use cWebColumn.pkg
Use cWebGroup.pkg
Use cWebCombo.pkg
Use cWebForm.pkg

Use cligaDataDictionary.dd
Use cequipoDataDictionary.dd
Use cjugadorDataDictionary.dd
Use cposicionDataDictionary.dd
Use cjugadorposicionDataDictionary.dd

Object oSelectJugador is a cWebView
    Set psCaption to "SelectJugador"
    Set peWebViewStyle to wvsDrilldown
    Set peViewType to vtSelect
    Set piColumnCount to 12
    Set pbShowCaption to False
    Set piMaxWidth to 1024

    Object oposicion_DD is a cposicionDataDictionary
    End_Object

    Object oliga_DD is a cligaDataDictionary
    End_Object 

    Object oequipo_DD is a cequipoDataDictionary
        Set DDO_Server to oliga_DD
    End_Object 

    Object ojugador_DD is a cjugadorDataDictionary
        Set DDO_Server to oequipo_DD
        
        // Reglas de filtrado dinámico basadas en las propiedades web de la vista
        Procedure OnConstrain
            String sNacionalidad sLiga sEquipo
            
            WebGet psValue of oFiltroNacionalidad to sNacionalidad
            WebGet psValue of oFiltroEquipo to sEquipo
            WebGet psValue of oFiltroLiga to sLiga
            
            If (sNacionalidad <> "") ;
                Constrain jugador.Nacionalidad eq sNacionalidad
                
            If (sEquipo <> "") ;
                Constrain equipo.Nombre eq sEquipo
                
            If (sLiga <> "") ;
                Constrain liga.Nombre eq sLiga
        End_Procedure
    End_Object 
    
    // Diccionario intermedio para conectar Jugador con sus Posiciones
    Object ojugadorposicion_DD is a cjugadorposicionDataDictionary
        Set DDO_Server to ojugador_DD
        Set DDO_Server to oposicion_DD
        Set Constrain_file to jugador.File_Number
    End_Object

    Set Main_DD to ojugador_DD
    Set Server  to ojugador_DD

    // --- SECCIÓN DE FILTROS SUPERIORES ---
    Object oFiltrosGroup is a cWebGroup
        Set piColumnCount to 12
        Set psCaption to "Filtros de Búsqueda"
        Set pbShowBorder to True
        Set piColumnSpan to 0

        Object oFiltroNacionalidad is a cWebCombo
            Set piColumnSpan to 4
            Set psLabel to "Nacionalidad:"
            Set peLabelPosition to lpTop
            
            // Llena el combo de forma manual/dinámica al cargar o usar OnFill
            Procedure OnFill
                Forward Send OnFill
                Send AddComboItem "" "Todas"
                // Aquí puedes recorrer tu base de datos o añadir manualmente:
                // Send AddComboItem "Argentina" "Argentina"
            End_Procedure
            
            Procedure OnChange String sNewValue String sOldValue
                Send RebuildAllConstraints of ojugador_DD
                Send RefreshList of oList
            End_Procedure
        End_Object

        Object oFiltroEquipo is a cWebCombo
            Set piColumnSpan to 4
            Set psLabel to "Equipo:"
            Set peLabelPosition to lpTop
            
            Procedure OnFill
                Forward Send OnFill
                Send AddComboItem "" "Todos"
                // Ejemplo para llenar desde base de datos de manera simple:
                // Clear equipo
                // Find ge equipo.Recnum
                // While (Found)
                //     Send AddComboItem equipo.Nombre equipo.Nombre
                //     Find gt equipo.Recnum
                // Loop
            End_Procedure

            Procedure OnChange String sNewValue String sOldValue
                Send RebuildAllConstraints of ojugador_DD
                Send RefreshList of oList
            End_Procedure
        End_Object

        Object oFiltroLiga is a cWebCombo
            Set piColumnSpan to 4
            Set psLabel to "Liga:"
            Set peLabelPosition to lpTop
            
            Procedure OnFill
                Forward Send OnFill
                Send AddComboItem "" "Todas"
            End_Procedure

            Procedure OnChange String sNewValue String sOldValue
                Send RebuildAllConstraints of ojugador_DD
                Send RefreshList of oList
            End_Procedure
        End_Object
    End_Object
    // --- FIN DE FILTROS ---

    Object oList is a cWebList
        Set piColumnSpan to 0
        Set psCSSClass to "MobileList"
        Set pbServerOnRowClick to True
        Set pbFillHeight to True
        Set pbShowHeader to False
        Set piSortColumn to 0

        Object ojugadorNombre is a cWebColumn
            Entry_Item jugador.Nombre
            Set psCaption to "jugador.Nombre"
            Set piWidth to 600
            Set psCSSClass to "RowCaption"
        End_Object 

        Object ojugadorApellido is a cWebColumn
            Entry_Item jugador.Apellido
            Set psCaption to "jugador.Apellido"
            Set piWidth to 600
            Set psCSSClass to "RowCaption"
        End_Object 

        Object ojugadorNacionalidad is a cWebColumn
            Entry_Item jugador.Nacionalidad
            Set psCaption to "jugador.Nacionalidad"
            Set piWidth to 500
            Set psCSSClass to "RowDetail"
        End_Object 

        Object oDetailButton is a cWebColumnButton
            Set psCaption to "btn"
            Set piWidth to 45
            Set pbFixedWidth to True
            Set pbResizable to False
            Set piListRowSpan to 3
            Set psBtnCssClass to "WebButtonIcon WebIcon_Info"
            Set peAlign to alignRight

            WebRegisterPath ntNavigateForward oZoomJugador

            Procedure OnClick
                Send NavigatePath
            End_Procedure

            Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView
                Move True to NavigateData.bReadOnly
            End_Procedure
        End_Object 

        Object oequipoNombre is a cWebColumn
            Entry_Item equipo.Nombre
            Set psCaption to "equipo.Nombre"
            Set piWidth to 1201
            Set pbNewLine to True
        End_Object 

        Object oligaNombre is a cWebColumn
            Entry_Item liga.Nombre
            Set psCaption to "liga.Nombre"
            Set piWidth to 1000
            Set pbNewLine to True
            Set psCSSClass to "RowDetail"
        End_Object 

        WebRegisterPath ntNavigateForward oZoomJugador

        Procedure OnRowClick String sRowId
            tWebNavigateData NavigateData
            Get GetNavigateData to NavigateData

            Case Begin
                Case (NavigateData.eNavigateType = nfFromParent)
                    Send NavigateForward of oZoomJugador Self
                    Case Break

                Case (NavigateData.eNavigateType = nfFromChild)
                    Send NavigateClose Self
                    Case Break

                Case (NavigateData.eNavigateType = nfFromMain)
                    Send NavigateClose Self
                    Case Break

                Case Else // must be nfUndefined
                    Send NavigateForward of oZoomJugador Self
            Case End
        End_Procedure

        Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView
            Move True to NavigateData.bReadOnly
        End_Procedure
    End_Object 

    Object oActionGroup is a cWebMenuGroup
        Object oSearch is a cWebMenuItem
            Set psCSSClass to "WebPromptMenuItem"
            Set psCaption to "Search"

            Procedure OnClick
                Send Search of oList
            End_Procedure
        End_Object 

        Object oNewButton is a cWebMenuItem
            Set psCSSClass to "WebClearMenuItem"
            Set psCaption to "New"

            WebRegisterPath ntNavigateForward oZoomJugador

            Procedure OnClick
                Send NavigatePath
            End_Procedure

            Procedure OnGetNavigateForwardData tWebNavigateData ByRef NavigateData Handle hoToView
                Move True to NavigateData.bNewRecord
            End_Procedure
        End_Object 
    End_Object 

    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
        WebSet pbRender of oNewButton to True
        WebSet pbRender of oDetailButton to True

        Case Begin
            Case (NavigateData.eNavigateType = nfFromParent)
                Case Break

            Case (NavigateData.eNavigateType = nfFromChild)
                Case Break

            Case (NavigateData.eNavigateType = nfFromMain)
                WebSet pbRender of oDetailButton to False
                Case Break

            Case Else 
        Case End
        
        Send SetHeaderCaption     "Select Jugadores"
        Send SetBreadcrumbCaption "Jugadores"
    End_Procedure
End_Object
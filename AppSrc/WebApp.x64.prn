37344>>>    Procedure DoLogin
37347>>>        String sLoginName sPassword sPrevStateHash
37347>>>        Boolean bResult
37347>>>        
37347>>>        WebGet psValue of oLoginName to sLoginName
37348>>>        WebGet psValue of oPassword to sPassword
37349>>>        
37349>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37350>>>        
37350>>>        If (bResult) Begin
37352>>>            Send Hide of oLogin
37353>>>            Send ShowHeader of ghoWebApp
37354>>>            WebSet psCSSClass of ghoWebApp to ""
37355>>>            
37355>>>            WebGet psPrevStateHash to sPrevStateHash
37356>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37357>>>            
37357>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37357>>>            WebSet psValue of oLoginName to ""
37358>>>            WebSet psValue of oPassword  to ""
37359>>>            WebSet pbVisible of oWarning to False
37360>>>        End
37360>>>>
37360>>>        Else Begin
37361>>>            WebSet pbVisible of oWarning to True
37362>>>        End
37362>>>>
37362>>>    End_Procedure
37363>>>    
37363>>>    Procedure OnSubmit
37366>>>        Send DoLogin
37367>>>    End_Procedure
37368>>>    
37368>>>    Procedure OnLoad
37371>>>        String sPrevStateHash sView
37371>>>        
37371>>>        Forward Send OnLoad
37373>>>        
37373>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37373>>>        Get StateHash of ghoWebApp to sPrevStateHash
37374>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37375>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37377>>>            WebSet psPrevStateHash to sPrevStateHash
37378>>>        End
37378>>>>
37378>>>        
37378>>>    End_Procedure

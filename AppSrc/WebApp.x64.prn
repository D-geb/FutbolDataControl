39795>>>    Procedure SetActionButtons
39798>>>        tWebNavigateData NavigateData
39798>>>        tWebNavigateData NavigateData
39798>>>        Boolean bHasRecord
39798>>>        Handle hoDD
39798>>>
39798>>>        Get Server to hoDD
39799>>>        Get GetNavigateData to NavigateData
39800>>>        Get HasRecord of hoDD to bHasRecord
39801>>>
39801>>>        // let's hide all buttons and then Show the ones we want
39801>>>        WebSet pbRender of oEditBtn to False
39802>>>        WebSet pbRender of oSaveBtn to False
39803>>>        WebSet pbRender of oCancelChangesBtn to False
39804>>>        WebSet pbRender of oDeleteBtn to False
39805>>>
39805>>>        If (NavigateData.bReadOnly) Begin
39807>>>            WebSet pbRender of oEditBtn to True
39808>>>        End
39808>>>>
39808>>>        Else Begin
39809>>>            WebSet pbRender of oSaveBtn to True
39810>>>            WebSet pbRender of oCancelChangesBtn to True
39811>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39812>>>        End
39812>>>>
39812>>>    End_Procedure

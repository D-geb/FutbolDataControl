36950>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36951>>>>>    
36951>>>>>    Procedure Construct_Object
36953>>>>>        Handle hoObj
36953>>>>>        
36953>>>>>        Forward Send Construct_Object
36955>>>>>        
36955>>>>>        Set pbSessionCookieHttpOnly to True
36956>>>>>        
36956>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36957>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36958>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36959>>>>>        
36959>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36960>>>>>        Set phoUserDD to hoObj
36961>>>>>        
36961>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36962>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36963>>>>>        Set phoSessionDD to hoObj
36964>>>>>        
36964>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36965>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36966>>>>>        Set phoCrypto to hoObj
36967>>>>>        
36967>>>>>        Property Boolean pbPasswordHashing True
36968>>>>>        
36968>>>>>        Property Boolean pbCreatingNewSession False
36969>>>>>        Property String psLoginName
36970>>>>>        Property String psUserName ""
36971>>>>>        Property Integer piUserRights 0
36972>>>>>    End_Procedure
36973>>>>>    
36973>>>>>    Procedure End_Construct_Object
36975>>>>>        Forward Send End_Construct_Object
36977>>>>>        
36977>>>>>        Handle hoCrypto
36977>>>>>        Integer iFieldLen
36977>>>>>        If (pbPasswordHashing(Self)) Begin
36979>>>>>            Get phoCrypto to hoCrypto
36980>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36983>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36985>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36986>>>>>>
36986>>>>>            End
36986>>>>>>
36986>>>>>        End
36986>>>>>>
36986>>>>>    End_Procedure
36987>>>>>    
36987>>>>>    Function CreateSession String sRemoteAddress Returns String
36989>>>>>        String sSessionKey
36989>>>>>        Integer iErr
36989>>>>>        Boolean bLogWebSession
36989>>>>>        Handle hoSessionDD       
36989>>>>>        Get phoSessionDD to hoSessionDD
36990>>>>>        
36990>>>>>        //  Get session key
36990>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36992>>>>>        
36992>>>>>        Get pbLogWebSession to bLogWebSession
36993>>>>>        If not bLogWebSession Begin
36995>>>>>            Function_Return sSessionKey        
36996>>>>>        End
36996>>>>>>
36996>>>>>
36996>>>>>        //  Store session
36996>>>>>        Send Clear of hoSessionDD
36997>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36998>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36999>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37000>>>>>        Get Request_Validate of hoSessionDD to iErr
37001>>>>>        If (iErr) Begin
37003>>>>>            // this should not happen. If it does its a programming error
37003>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37004>>>>>>
37004>>>>>            Function_Return ""
37005>>>>>        End
37005>>>>>>
37005>>>>>        Send Request_Save of hoSessionDD
37006>>>>>        If (Err) Begin
37008>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37008>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37009>>>>>>
37009>>>>>            Function_Return ""
37010>>>>>        End
37010>>>>>>
37010>>>>>       
37010>>>>>        Function_Return sSessionKey        
37011>>>>>    End_Function
37012>>>>>    
37012>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37014>>>>>        DateTime dtLastAccess dtCurrent
37014>>>>>        TimeSpan tsDiff
37014>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37014>>>>>        Boolean bResult bCreatingNewSession
37014>>>>>        Boolean bLogWebSession bLoadWebApp
37014>>>>>        Integer eLoginMode
37014>>>>>        String sTime
37014>>>>>        Handle hoSessionDD hoUserDD       
37014>>>>>        
37014>>>>>        Move False to bLoadWebApp
37015>>>>>        If (num_arguments >= 2) Begin
37017>>>>>            Move bOptLoadWebApp to bLoadWebApp
37018>>>>>        End
37018>>>>>>
37018>>>>>        
37018>>>>>        Get phoSessionDD to hoSessionDD
37019>>>>>        Get phoUserDD to hoUserDD
37020>>>>>        
37020>>>>>        Get pbLogWebSession to bLogWebSession
37021>>>>>        Get peLoginMode to eLoginMode
37022>>>>>        
37022>>>>>        // for this object, you can only disable logging if login completely is disabled
37022>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37024>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37025>>>>>>
37025>>>>>            Function_Return False
37026>>>>>        End
37026>>>>>>
37026>>>>>
37026>>>>>        //  Clear session properties
37026>>>>>        Set psSessionKey to ""
37027>>>>>        Send UpdateSessionProperties True
37028>>>>>        
37028>>>>>        If not bLogWebSession Begin
37030>>>>>            Forward Get ValidateSession sSessionKey to bResult
37032>>>>>            Function_Return bResult
37033>>>>>        End        
37033>>>>>>
37033>>>>>        
37033>>>>>        Move False to bResult
37034>>>>>        Get piSessionTimeout to iSessionTimeout 
37035>>>>>        
37035>>>>>        //  Check if session exists
37035>>>>>        Send Clear of hoSessionDD
37036>>>>>        Move sSessionKey to WebAppSession.SessionKey
37037>>>>>        Send Find of hoSessionDD EQ Index.1
37038>>>>>            
37038>>>>>        If (Found) Begin
37040>>>>>            //  Calculate timespan between now and last access time
37040>>>>>            Move (CurrentDateTime()) to dtCurrent
37041>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37042>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37043>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37044>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37045>>>>>            
37045>>>>>            //  Check if session didn't time out
37045>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37047>>>>>                Forward Get ValidateSession sSessionKey to bResult
37049>>>>>                   
37049>>>>>                If (bResult) Begin
37051>>>>>                    //  Update session record
37051>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37052>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37053>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37054>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37055>>>>>                    Get Request_Validate of hoSessionDD to iErr
37056>>>>>                    If (iErr) Begin
37058>>>>>                        // this should not happen. If it does its a programming error
37058>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37059>>>>>>
37059>>>>>                        Function_Return False
37060>>>>>                    End
37060>>>>>>
37060>>>>>                    Send Request_Save of hoSessionDD
37061>>>>>                    
37061>>>>>                    //  Update user properties
37061>>>>>                    Send UpdateSessionProperties False
37062>>>>>                End
37062>>>>>>
37062>>>>>            End
37062>>>>>>
37062>>>>>            Else Begin
37063>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37063>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37064>>>>>                
37064>>>>>                If (not(bCreatingNewSession)) Begin
37066>>>>>                    If (not(bLoadWebApp)) Begin
37068>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37069>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37070>>>>>>
37070>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37071>>>>>                    End
37071>>>>>>
37071>>>>>                    Else Begin
37072>>>>>                        Set pbCreatingNewSession to True                    
37073>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37074>>>>>                        Set pbCreatingNewSession to False                        
37075>>>>>                    End
37075>>>>>>
37075>>>>>                End
37075>>>>>>
37075>>>>>            End
37075>>>>>>
37075>>>>>        End
37075>>>>>>
37075>>>>>        Else Begin
37076>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37077>>>>>>
37077>>>>>        End
37077>>>>>>
37077>>>>>        
37077>>>>>        Function_Return bResult
37078>>>>>    End_Function
37079>>>>>    
37079>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37081>>>>>        If (not(pbPasswordHashing(Self))) Begin
37083>>>>>            Move sPassword to sHash
37084>>>>>            Function_Return True
37085>>>>>        End
37085>>>>>>
37085>>>>>        
37085>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37087>>>>>            Function_Return False
37088>>>>>        End
37088>>>>>>
37088>>>>>        Move ("V1$" + sHash) to sHash
37089>>>>>        Function_Return True
37090>>>>>    End_Function
37091>>>>>    
37091>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37093>>>>>        If (not(pbPasswordHashing(Self))) Begin
37095>>>>>            Move False to bShouldUpgrade
37096>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37097>>>>>        End
37097>>>>>>
37097>>>>>        
37097>>>>>        String sVersion
37097>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37098>>>>>        If (sVersion = "V1$") Begin
37100>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37103>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37104>>>>>        End
37104>>>>>>
37104>>>>>        Else Begin
37105>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37108>>>>>            Function_Return False
37109>>>>>        End
37109>>>>>>
37109>>>>>    End_Function
37110>>>>>    
37110>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37112>>>>>        Handle hoUserDD
37112>>>>>        Integer iErr
37112>>>>>        Get phoUserDD to hoUserDD
37113>>>>>        
37113>>>>>        //  Find the user
37113>>>>>        Send Clear of hoUserDD
37114>>>>>        Move sLoginName to WebAppUser.LoginName
37115>>>>>        Send Find of hoUserDD EQ Index.1
37116>>>>>        If (Found) Begin
37118>>>>>            Send Clear of hoUserDD
37119>>>>>            Function_Return False
37120>>>>>        End
37120>>>>>>
37120>>>>>        
37120>>>>>        Send Clear of hoUserDD
37121>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37122>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37123>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37125>>>>>            Send Clear of hoUserDD
37126>>>>>            Function_Return False
37127>>>>>        End
37127>>>>>>
37127>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37128>>>>>        Get Request_Validate of hoUserDD to iErr
37129>>>>>        If (iErr) Begin
37131>>>>>            Send Clear of hoUserDD
37132>>>>>            Function_Return False
37133>>>>>        End
37133>>>>>>
37133>>>>>        
37133>>>>>        Send Request_Save of hoUserDD
37134>>>>>        Function_Return (not(Err))

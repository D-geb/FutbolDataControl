39823>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39826>>>        Handle hoDD
39826>>>        RowID riJugador
39826>>>        Get Server to hoDD
39827>>>        
39827>>>        Forward Send OnNavigateForward NavigateData hoInvokingView hoInvokingObject
39829>>>        Case Begin
39829>>>            Case (NavigateData.eNavigateType = nfFromMain)
39831>>>                // PASO CLAVE: Convertir el String sRowId a un tipo RowID real
39831>>>                Move (DeserializeRowID(NavigateData.sRowId)) to riJugador
39832>>>                // Ahora pasamos la variable riJugador (que ya es RowID) en lugar del String
39832>>>                Send FindByRowId of hoDD jugador.File_Number riJugador
39833>>>                Case Break
39834>>>
39834>>>            //Case (NavigateData.eNavigateType = nfFromParent)
39834>>>                // If from parent, this is a constrained drill down.
39834>>>                //Case Break
39834>>>
39834>>>            //Case (NavigateData.eNavigateType = nfFromChild)
39834>>>                // If from child, this is a probably a parent Zoom from a Zoom.
39834>>>                //Case Break
39834>>>
39834>>>            //Case Else // must be nfUndefined
39834>>>
39834>>>        Case End
39834>>>        
39834>>>        If (HasRecord(hoDD)) Begin 
39836>>>            // Corregido: Usamos '+' y Trim para una mejor presentación del título
39836>>>            Send SetHeaderCaption ("Jugador: " + Trim(jugador.Nombre) + " " + Trim(jugador.Apellido) + " (" + Trim(equipo.Nombre) + ")")
39837>>>            Send SetBreadcrumbCaption (Trim(jugador.Nombre) + " " + Trim(jugador.Apellido))
39838>>>        End
39838>>>>
39838>>>        Else Begin 
39839>>>            Send SetHeaderCaption "Nuevo Jugador"
39840>>>            Send SetBreadcrumbCaption "Nuevo"
39841>>>        End
39841>>>>
39841>>>
39841>>>        Send SetActionButtons
39842>>>
39842>>>    End_Procedure
39843>>>
39843>>>End_Object 

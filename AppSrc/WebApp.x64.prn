37213>>>>>    
37213>>>>>    //
37213>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37213>>>>>    // update properties based on the session and user data. Augment this function to update 
37213>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37213>>>>>    // the right records when this procedure is called.
37213>>>>>    //
37213>>>>>    // Params:
37213>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37213>>>>>    //
37213>>>>>    Procedure UpdateSessionProperties Boolean bClear
37215>>>>>        Handle hoUserDD
37215>>>>>        
37215>>>>>        Get phoUserDD to hoUserDD
37216>>>>>        
37216>>>>>        //  Update user properties
37216>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37218>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37219>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37220>>>>>            Set piUserRights to WebAppUser.Rights
37221>>>>>            
37221>>>>>            Send OnSessionPropertiesSet 
37222>>>>>        End
37222>>>>>>
37222>>>>>        Else Begin
37223>>>>>            Set psUsername to ""
37224>>>>>            Set psLoginName to ""
37225>>>>>            Set piUserRights to 0
37226>>>>>            
37226>>>>>            Send OnSessionPropertiesClear
37227>>>>>        End
37227>>>>>>
37227>>>>>    End_Procedure
37228>>>>>    
37228>>>>>    Procedure OnSessionPropertiesSet
37230>>>>>        //  Empty event stub
37230>>>>>    End_Procedure
37231>>>>>    
37231>>>>>    Procedure OnSessionPropertiesClear
37233>>>>>        //  Empty event stub
37233>>>>>    End_Procedure
37234>>>>>    
37234>>>>>    Procedure EndSession
37236>>>>>        Integer iErr
37236>>>>>        Boolean bLogWebSession
37236>>>>>        Handle hoSessionDD       
37236>>>>>        
37236>>>>>        Get phoSessionDD to hoSessionDD
37237>>>>>        Get pbLogWebSession to bLogWebSession
37238>>>>>        If not bLogWebSession Begin
37240>>>>>            Forward Send EndSession
37242>>>>>            Procedure_Return
37243>>>>>        End
37243>>>>>>
37243>>>>>            
37243>>>>>        //  Check if session exists
37243>>>>>        Send Clear of hoSessionDD
37244>>>>>        Get psSessionKey to WebAppSession.SessionKey
37245>>>>>        
37245>>>>>        Send Find of hoSessionDD EQ Index.1
37246>>>>>        If (Found) Begin
37248>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37249>>>>>            Get Request_Validate of hoSessionDD to iErr
37250>>>>>            If (iErr) Begin
37252>>>>>                // this should not happen. If it does its a programming error
37252>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37253>>>>>>
37253>>>>>                Procedure_Return
37254>>>>>            End
37254>>>>>>
37254>>>>>            Send Request_Save of hoSessionDD
37255>>>>>        End
37255>>>>>>
37255>>>>>    End_Procedure

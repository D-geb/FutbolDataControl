38285>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38288>>>        WebSet pbRender of oNewButton to True
38289>>>        WebSet pbRender of oDetailButton to True
38290>>>
38290>>>        Case Begin
38290>>>            Case (NavigateData.eNavigateType = nfFromParent)
38292>>>                // If from parent, this is a constrained drill down
38292>>>                Case Break
38293>>>
38293>>>            Case (NavigateData.eNavigateType = nfFromChild)
38296>>>                // If from child, this is a probably a parent lookup from a Zoom
38296>>>                Case Break
38297>>>
38297>>>            Case (NavigateData.eNavigateType = nfFromMain)
38300>>>                // If from main, this is a probably a main-file lookup from a Zoom
38300>>>                WebSet pbRender of oDetailButton to False
38301>>>                Case Break
38302>>>
38302>>>            Case Else // must be nfUndefined
38302>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38302>>>
38302>>>        Case End
38302>>>        
38302>>>        Send SetHeaderCaption     "Select Equipos"
38303>>>        Send SetBreadcrumbCaption "Equipos"
38304>>>
38304>>>    End_Procedure
